rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(data) {
      return request.auth != null
        && (
          data.user_id == request.auth.uid
          || data.uid == request.auth.uid
          || data.userId == request.auth.uid
        );
    }

    function sessionIdOwned(sessionId) {
      return request.auth != null
        && sessionId.matches('^' + request.auth.uid + '_.*$');
    }

    function prefixedDocOwned(docId) {
      return request.auth != null
        && docId.matches('^' + request.auth.uid + '_.*$');
    }

    // ── Profiles ──────────────────────────────────────────────────────
        // Users can read public profiles and write their own profile.
        // Non-owners can only touch follower_count for social graph counters.
    match /profiles/{userId} {
       allow read:   if request.auth != null
               && (
                 request.auth.uid == userId
                 || resource.data.profile_visibility != 'private'
               );
      allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.email is string
                       && request.resource.data.name is string
                       && request.resource.data.onboarding_complete is bool;
       allow update: if request.auth != null
               && (
                 (
                request.auth.uid == userId
                 )
                 || (
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['follower_count'])
                   && (
                     request.resource.data.follower_count is int
                     || request.resource.data.follower_count is float
                   )
                 )
               );
      allow delete: if false; // Never allow profile deletion via client
    }

    // ── Usernames (reverse lookup) ─────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
                       && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Workout Templates ─────────────────────────────────────────────
    // User-owned templates. Public templates (is_public == true) are readable
    // by any authenticated user for the Discover feed.
    match /workout_templates/{templateId} {
      allow read:   if isOwner(resource.data)
                       || (request.auth != null && resource.data.is_public == true);
      allow create: if request.auth != null
                       && (
                            request.resource.data.user_id == request.auth.uid
                            || request.resource.data.userId == request.auth.uid
                          );
      allow update: if isOwner(resource.data);
      allow delete: if isOwner(resource.data);
    }

    // ── Completed Workout Sessions ────────────────────────────────────
    // Immutable history records — users can create and read their own.
    match /workout_sessions_completed/{sessionId} {
      allow read: if request.auth != null
                     && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // History is immutable
    }

    // ── Weekly Workout Plans ──────────────────────────────────────────
    // Generated week schedules with explicit rest/workout day assignment.
    match /workout_week_plans/{planId} {
      allow read: if request.auth != null
                     && (
                          (resource != null && resource.data.user_id == request.auth.uid)
                          || (resource == null && prefixedDocOwned(planId))
                        );
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Workout Daily Overrides ──────────────────────────────────────
    // Day-level adaptations applied without mutating the weekly base plan.
    match /workout_daily_overrides/{overrideId} {
      allow read: if request.auth != null
                     && (
                          (resource != null && resource.data.user_id == request.auth.uid)
                          || (resource == null && prefixedDocOwned(overrideId))
                        );
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Paused Workout Sessions ───────────────────────────────────────
    match /workout_sessions/{sessionId} {
      allow read: if request.auth != null
                     && (
                          resource == null
                          || isOwner(resource.data)
                          || sessionIdOwned(sessionId)
                        );
      allow create: if request.auth != null
                       && (
                            request.resource.data.user_id == request.auth.uid
                            || request.resource.data.uid == request.auth.uid
                            || request.resource.data.userId == request.auth.uid
                          );
      allow update: if request.auth != null
                       && resource != null
                       && (
                            isOwner(resource.data)
                            || sessionIdOwned(sessionId)
                          )
                       && (
                            request.resource.data.user_id == request.auth.uid
                            || request.resource.data.uid == request.auth.uid
                            || request.resource.data.userId == request.auth.uid
                          );
      allow delete: if request.auth != null
                       && (
                            resource == null
                            || isOwner(resource.data)
                            || sessionIdOwned(sessionId)
                          );
    }

    // ── Nutrition Logs ────────────────────────────────────────────────
    match /nutrition_logs/{logId} {
      allow read: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Diet Plans ────────────────────────────────────────────────────
    match /diet_plans/{planId} {
      allow read: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Food Library ──────────────────────────────────────────────────
    match /food_library/{itemId} {
      allow read: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Water Logs ────────────────────────────────────────────────────
    match /water_logs/{waterLogId} {
      allow read: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── User Pantry ───────────────────────────────────────────────────
    match /users/{userId}/pantry/{itemId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Nutrition Settings ───────────────────────────────────────────
    match /nutrition_settings/{userId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Meal Templates ────────────────────────────────────────────────
    match /meal_templates/{templateId} {
      allow read: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.user_id == request.auth.uid
                       && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;
    }

    // ── Exercise Library ─────────────────────────────────────────────
    // Read-only for all authenticated users; writes only via Admin SDK.
    match /exercises/{exerciseId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Community Posts ───────────────────────────────────────────────
    match /community_posts/{postId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.author_id == request.auth.uid;
      allow update: if request.auth != null
                       && (resource.data.author_id == request.auth.uid
                           || request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['like_count','liked_by','comment_count','flagged_count','flagged_reason','status']));
      allow delete: if request.auth != null
                       && resource.data.author_id == request.auth.uid;
    }

    // ── Community Comments ────────────────────────────────────────────
    match /community_posts/{postId}/comments/{commentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.author_id == request.auth.uid;
      allow update: if request.auth != null
               && (
                 resource.data.author_id == request.auth.uid
                 || request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['like_count'])
               );
      allow delete: if request.auth != null
                       && resource.data.author_id == request.auth.uid;
    }

    // ── Community Follows ─────────────────────────────────────────────
    match /community_follows/{followId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.follower_id == request.auth.uid;
      allow update: if request.auth != null
                       && resource.data.follower_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.follower_id == request.auth.uid;
    }

    // ── User Blocks ───────────────────────────────────────────────────
    match /user_blocks/{blockId} {
      allow read:   if request.auth != null
                       && (resource.data.blocker_id == request.auth.uid
                           || resource.data.blocked_id == request.auth.uid);
      allow create: if request.auth != null
                       && request.resource.data.blocker_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.blocker_id == request.auth.uid;
    }

    // ── User Mutes ────────────────────────────────────────────────────
    match /user_mutes/{muteId} {
      allow read:   if request.auth != null
                       && resource.data.muter_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.muter_id == request.auth.uid;
      allow delete: if request.auth != null
                       && resource.data.muter_id == request.auth.uid;
    }

    // ── Community Groups ──────────────────────────────────────────────
    match /community_groups/{groupId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.creator_id == request.auth.uid;
      allow update: if request.auth != null
               && (
                 resource.data.creator_id == request.auth.uid
                 || request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['member_count'])
               );
      allow delete: if request.auth != null
                       && resource.data.creator_id == request.auth.uid;
    }

    // ── Group Members ─────────────────────────────────────────────────
    match /community_groups/{groupId}/members/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Challenge Participants ────────────────────────────────────────
    match /challenge_participants/{challengeId}/participants/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['score','rank','progress_history','trend','completed','completed_at','updated_at']);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Group Check-ins ───────────────────────────────────────────────
    match /group_check_ins/{groupId}/check_ins/{checkInId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['like_count','liked_by','comment_count']);
      allow delete: if request.auth != null
                       && resource.data.user_id == request.auth.uid;

      match /comments/{commentId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                         && resource.data.author_id == request.auth.uid;
      }
    }

    // ── Content Reports ───────────────────────────────────────────────
    match /content_reports/{reportId} {
      allow read:   if request.auth != null
                       && resource.data.reporter_id == request.auth.uid;
      allow create: if request.auth != null
                       && request.resource.data.reporter_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{uid}/events/{eventId} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Default deny ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
