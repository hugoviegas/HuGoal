rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidAvatarUpload() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatars path used by the app:
    // avatars/{uid}/{timestamp}.jpg
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidAvatarUpload();
      allow delete: if isOwner(userId);
    }

    function isValidWorkoutCoverUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Workout cover images:
    // workout-covers/{uid}/{timestamp}.jpg
    match /workout-covers/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidWorkoutCoverUpload();
      allow delete: if isOwner(userId);
    }

    // Community group avatars:
    // community_groups/{uid}/{timestamp}.jpg
    match /community_groups/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidWorkoutCoverUpload();
      allow delete: if isOwner(userId);
    }

    // Group check-in images:
    // group_check_ins/{groupId}/{uid}/{timestamp}.jpg
    match /group_check_ins/{groupId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }

    function isValidNutritionAudioUpload() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    function isValidNutritionImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Nutrition temporary audio:
    // users/{uid}/nutrition/audio/{date}/{timestamp}.m4a
    match /users/{userId}/nutrition/audio/{date}/{fileName} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidNutritionAudioUpload();
      allow delete: if isOwner(userId);
    }

    // Nutrition temporary images:
    // users/{uid}/nutrition/images/{date}/{timestamp}.jpg
    match /users/{userId}/nutrition/images/{date}/{fileName} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidNutritionImageUpload();
      allow delete: if isOwner(userId);
    }

    // Default deny for everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}