{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "constants/**/*.ts",
    "hooks/**/*.ts",
    "lib/**/*.ts",
    "locales/**/*.json",
    "stores/**/*.ts",
    "types/**/*.ts",
    "scripts/**/*.js",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "global.css"
  ],
  "exclude": [
    "node_modules",
    "betteru",
    "pixel-agents",
    ".expo"
  ]
}
